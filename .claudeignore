# .claudeignore
# Claude Harness Engineering: Token Leaks Prevention List

# 1. Environment & Cache (High Token Waste)
.venv/
node_modules/
__pycache__/
*.pyc

# 2. Large Binary & Task Inputs (Very Expensive)
*.docx
*.pdf
*.pptx
tmp_jeil.docx

# 3. Dynamic Outputs (Unnecessary Context)
outputs/
docs/
state/
incoming_tasks/

# 4. System & Hidden Files
.git/
.DS_Store
.cursor/
.idea/
.vscode/

# 5. Env & Credentials (Security & Useless Context)
.env
credentials.json
token.json
