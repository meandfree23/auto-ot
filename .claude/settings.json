{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/kk/Desktop/오티 자동화/.claude/hooks/session-context.sh'",
            "timeout": 10,
            "statusMessage": "프로젝트 상태 로딩 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/kk/Desktop/오티 자동화/.claude/hooks/python-syntax-check.sh'",
            "timeout": 10,
            "statusMessage": "Python 문법 검사 중..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/kk/Desktop/오티 자동화/.claude/hooks/pre-compact-snapshot.sh'",
            "timeout": 10,
            "statusMessage": "작업 상태 스냅샷 저장 중..."
          }
        ]
      }
    ]
  }
}
